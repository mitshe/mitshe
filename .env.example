# mitshe environment configuration
# Copy this file to .env and fill in your values

# ===========================================
# Authentication Mode
# ===========================================
# selfhosted = Email/password JWT auth (default)
# clerk = Clerk authentication (multi-org, SSO)
AUTH_MODE=selfhosted
NEXT_PUBLIC_AUTH_MODE=selfhosted

# ===========================================
# Clerk Authentication (required only if AUTH_MODE=clerk)
# Get keys from https://clerk.com
# ===========================================
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ===========================================
# Database
# ===========================================
# PostgreSQL (development/production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mitshe

# SQLite (light mode only)
# DATABASE_URL=file:./data/mitshe.db

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT secret for selfhosted auth (required in selfhosted mode, min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ===========================================
# Application URLs
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Backend internal URL (used by Next.js server-side)
BACKEND_URL=http://localhost:3001

# ===========================================
# Optional: Monitoring
# ===========================================
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENABLED=false

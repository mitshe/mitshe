# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3001

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_tasks?schema=public

# =============================================================================
# Redis (for BullMQ queues and rate limiting)
# REDIS_URL takes priority over REDIS_HOST/REDIS_PORT
# =============================================================================
REDIS_URL=redis://localhost:6379
# Or use separate host/port (fallback if REDIS_URL not set):
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Security
# Generate encryption key with: openssl rand -hex 32
# =============================================================================
ENCRYPTION_KEY=your-32-byte-hex-key-here

# =============================================================================
# Clerk Authentication
# Get these from https://dashboard.clerk.com
# =============================================================================
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Optional: Default AI Provider Keys (for platform-provided AI)
# Users can also bring their own keys (BYOK)
# =============================================================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Error Tracking (Sentry)
# Get DSN from https://sentry.io
# =============================================================================
SENTRY_ENABLED=false
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================================
# API Configuration
# =============================================================================
API_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
